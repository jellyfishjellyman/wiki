{
  "version": 1,
  "lines": {
    "load": ["欢迎来到 GWB Wiki。"],
    "relax": ["我在这里看云。"],
    "click": ["需要搜索资料的话，可以点上面的搜索框。"],
    "error": ["看板娘资源暂时没有加载成功。"]
  },
  "rules": [
    {
      "event": "load",
      "text": ["欢迎来到 GWB Wiki。"]
    },
    {
      "selector": ".home-search",
      "event": "mouseenter",
      "text": ["这里可以搜索整个 Wiki。"],
      "action": "touch"
    },
    {
      "selector": ".home-links a",
      "event": "mouseenter",
      "text": ["这是一条快速入口。"]
    },
    {
      "selector": ".home-card",
      "event": "mouseenter",
      "text": ["云和水母都在这里。"],
      "action": "touch"
    }
  ]
}
